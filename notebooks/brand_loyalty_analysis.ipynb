      "metadata": {},
      "source": [
        "# Smartphone Brand Loyalty Analysis (Leakage-Free, Binary)\n",
        "\n",
        "This notebook covers data loading, EDA, leakage-free preprocessing, binary target transformation (Loyal vs Not Loyal), model training, evaluation, and insights."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import json\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "from src.brand_loyalty.train_project import train_project\n",
        "from src.brand_loyalty.data import load_dataset\n",
        "from src.brand_loyalty.config import CFG"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "df_raw = pd.read_excel('project dataset.xlsx')\n",
        "print('Shape:', df_raw.shape)\n",
        "print('Columns:', list(df_raw.columns))\n",
        "df_raw.head(3)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "0c67a4c4",
      "metadata": {},
      "outputs": [],
      "source": [
        "target_col = 'How likely are you to continue using this brand in the future?'\n",
        "\n",
        "# Raw 3-class target distribution\n",
        "sns.countplot(data=df_raw, x=target_col)\n",
        "plt.xticks(rotation=15)\n",
        "plt.title('Raw Target Distribution (3 Classes)')\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# Binary target: Loyal (Very likely + Somewhat likely) vs Not Loyal (Not likely)\n",
        "y_bin = df_raw[target_col].map({'Not likely': 0, 'Somewhat likely': 1, 'Very likely': 1})\n",
        "print('Binary class counts:')\n",
        "print(y_bin.value_counts().rename(index={0: 'Not Loyal', 1: 'Loyal'}))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Run synchronized leakage-free training pipeline\n",
        "train_project(dataset_path=CFG.dataset_path, output_dir='artifacts')"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "report = json.loads(open('artifacts/reports/project_experiment_metadata.json', 'r', encoding='utf-8').read())\n",
        "pd.DataFrame(report['models'])"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "print('Best model:', report['best_model'])\n",
        "print('Best accuracy:', report['best_accuracy'])\n",
        "print('Top RF features:')\n",
        "for row in report['rf_top_features'][:10]:\n",
        "    print('-', row['feature'], '=>', round(row['importance'], 4))"
      ]
    }
