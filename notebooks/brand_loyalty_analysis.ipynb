   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "target_col = CFG.source_target_col\n",
    "sns.countplot(data=df, x=target_col)\n",
    "plt.xticks(rotation=15)\n",
    "plt.title('Raw Target Distribution (3 classes)')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "y_bin = df[target_col].map({'Not likely': 0, 'Somewhat likely': 1, 'Very likely': 1})\n",
    "sns.countplot(x=y_bin.map({0: 'Not Loyal', 1: 'Loyal'}))\n",
    "plt.title('Binary Target Distribution')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
